# --- LLM providers (at least one required) ---
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- database / cache ---
DATABASE_URL=postgresql+asyncpg://sarathi:sarathi@localhost:5432/sarathi
REDIS_URL=redis://localhost:6379/0
# prod compose only (infra/docker-compose.prod.yml): generate a strong password,
# e.g. `openssl rand -base64 24`. Never reuse the dev default.
POSTGRES_USER=sarathi
POSTGRES_PASSWORD=
POSTGRES_DB=sarathi

# --- auth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Generate a real secret for prod: python -c "import secrets; print(secrets.token_urlsafe(48))"
# (boot refuses the placeholder below when APP_ENV != dev)
JWT_SECRET=change-me
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000
# Cookie Domain: leave empty for single-host dev; set to e.g. .niheshr.com in prod when
# the frontend and API live on sibling subdomains so the session cookie is shared.
COOKIE_DOMAIN=
# Credentialed origins allowed to call the API (JSON array). Add the https frontend in prod.
CORS_ORIGINS=["http://localhost:3000"]

# --- email (AWS SES ap-south-1) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
SES_FROM_ADDRESS=no-reply@niheshr.com

# --- app ---
APP_ENV=dev
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# --- console (comma-separated; empty + APP_ENV=dev = any authed user is staff) ---
STAFF_EMAILS=

# --- proactive scheduler (runs inside the worker process; see infra/DEPLOY.md) ---
# ON by default: every SWEEP_INTERVAL_SECONDS it reviews up to SWEEP_BATCH_SIZE
# quiet customers (has an account, no agent run in SWEEP_CUSTOMER_COOLDOWN_DAYS) and
# runs the adoption agent for them. SWEEP_DAILY_CAP hard-limits sweeps per UTC day.
# Cost note: sweeps only run when under LLM_DAILY_BUDGET_USD, and with gpt-4o-mini a
# full cap-day (10 sweeps) costs roughly 10 x $0.002 ~= $0.02. Set SCHEDULER_ENABLED=false
# to turn the loop off entirely (also honored as a kill switch mid-run).
SCHEDULER_ENABLED=true
SWEEP_INTERVAL_SECONDS=3600
SWEEP_CUSTOMER_COOLDOWN_DAYS=7
SWEEP_BATCH_SIZE=3
SWEEP_DAILY_CAP=10
